<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Upload File</title>
  </head>

  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
      <h5 class="mb-5">Upload Profile Pic</h5>

      <form action="/upload" method="post" enctype="multipart/form-data">
        <!-- multer does not work if multipart not mentioned -->
        <input
          type="file"
          name="image"
          class="resize-none bg-transparent border-2 border-zinc-800 rounded-md w-1/3 outline-none p-3 block"
        />

        <input
          type="submit"
          class="px-3 py-2 bg-yellow-500 rounded-md block mt-2 w-40"
          value="Upload File"
        />
      </form>
    </div>
  </body>
</html>

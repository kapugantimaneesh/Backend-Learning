<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
  </head>
  <body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
      <a
        href="/logout"
        class="bg-red-500 px-3 py-2 rounded-md text-sm mb-5 inline-block"
        >LogOut</a
      >
      <div class="flex item-start gap-3">
        <div class="w-10 h-10  rounded-md">
          <img class="w-full h-full object-cover" src="/images/uploads/<%= user.profilepic %>" alt="">
        </div>
        <h1 class="text-3xl mb-5">
        <span class="font-light">Hello</span>,<%= user.name %>
        </h1>
      </div>
      
      <h5 class="mb-5">you can create a post</h5>
      <form action="/post" method="post">
        <textarea
          class="resize-none bg-transparent border-2 border-zinc-800 rounded-md w-1/3 outline-none p-3 block"
          placeholder="what's on your mind"
          id=""
          name="content"
        ></textarea>
        <input
          type="submit"
          class="px-3 py-2 bg-blue-500 rounded-md block mt-2 w-40"
          value="Create new Post"
        />
      </form>
      <div class="posts mt-20">
        <h3 class="text-zinc-400 mb-5">Your Posts</h3>
        <div class="postcontainer">
          <% user.posts.forEach((val)=>{ %>
            <div class="post w-1/3 p-4 border-2 border-zinc-800 mb-2 rounded-md">
            <h4 class="text-blue-400 mb-2">@<%= user.username %></h4>
            <h4>
              <%= val.content %>
            </h4>   
            <div class="btns flex gap-4 mt-5">
              <small class="mt-1 inline-block"><%= val.likes.length %></small>
              <a class="text-blue-500" href="/like/<%= val._id %>">
                <%= val.likes.indexOf(user._id)!=-1 ? "Unlike" :"Like" %>
              </a>
              <a class="text-zinc-600" href="/edit/<%= val._id %>">Edit</a>
            </div>
          </div>
          <% }) %>
          
          
        </div>
      </div>
    </div>
  </body>
</html>

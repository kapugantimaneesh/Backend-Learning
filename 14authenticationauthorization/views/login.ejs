<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>
  </head>
  <body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
      <form action="/login" method="post">
        <h3 class="text-3xl mb-3">Login</h3>
        <input
          class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800 outline-none"
          type="email"
          name="email"
          placeholder="email"
        />
        <input
          class="px-3 py-2 rounded-md bg-transparent border-2 border-zinc-800 outline-none"
          type="password"
          name="password"
          placeholder="password"
        />

        <input
          class="px-45 py-2 rounded-md bg-blue-500 border-2 border-zinc-800 outline-none"
          type="submit"
          name="submit"
          value="Login"
        />
      </form>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Document</title>
  </head>

  <body class="h-screen">
    <div class="w-full h-full bg-zinc-900 p-10 text-white">
      <div class="nav mb-10">
        <a class="text-blue-500" href="/">Back to home</a>
      </div>
      <h1 class="text-3xl tracking-tighter mb-5">All Users 😎</h1>
      <div class="users flex gap-3 flex-wrap">
        <% users.forEach((val)=>{ %>
            <div class="user w-72 p-4 bg-zinc-800 rounded-lg">
                <div class="w-full h-52 bg-zinc-500">
                    <img src="<%= val.imgur %>" class="w-full h-full object-cover" alt="">
                </div>
                    <h3 class="text-xl mt-3 tracking-tighter"><%= val.name %></h3>
                    <h5 class="text-zinc-500"><%= val.email %></h5>
                    <div class="flex gap-3 mt-10">
                        <a class="text-zinc-600" href="/edit/<%= val.name %>">Edit User</a>
                        <a href="/delete/<%= val.name %>" class="text-red-500">Delete User</a>
                    </div>
                </div>
            
        <% })%>
        
      </div>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Document</title>
  </head>

  <body class="h-screen">
    <div class="w-full h-full bg-zinc-900 p-10 text-white">
      <div class="nav mb-10">
        <a class="text-blue-500" href="/read">read Users</a>
      </div>
      <h1 class="text-3xl tracking-tighter mb-5">Create User 😗</h1>
      <form action="/create" method="post">
        <input
          class="px-5 py-3 bg-transparent border-2 border-zinc-700 rounded outline-none focus:border-blue-500"
          type="text"
          name="name"
          placeholder="name"
        />
        <input
          class="px-5 py-3 bg-transparent border-2 border-zinc-700 rounded outline-none focus:border-blue-500"
          type="text"
          name="email"
          placeholder="email"
        />
        <input
          class="px-70 py-3 bg-transparent border-2 border-zinc-700 rounded outline-none focus:border-blue-500"
          type="text"
          name="imgur"
          placeholder="img url"
        />
        <input
          class="px-5 py-2 bg-blue-500 rounded-lg ml-3"
          type="submit"
          value="create a user"
        />
      </form>
    </div>
  </body>
</html>
